{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Otp": {
    "UseFixedInDevelopment": true,
    "FixedCode": "999999"
  },
  "Admin": {
    "AllowAdminRegistration": true,
    "AllowMultipleAdmins": true
  },
  "Database": {
    "AutoMigrate": false
  }
}
