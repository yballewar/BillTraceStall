@page "/office/payments"
@inject BillTraceStall.Admin.Services.AdminApiClient Api

<h3>Payments</h3>

<div class="row mb-3">
    <div class="col-12 col-md-3">
        <label class="form-label">Month</label>
        <input class="form-control" type="month" value="@MonthValue" @onchange="OnMonthChanged" />
    </div>
    <div class="col-12 col-md-3 d-flex align-items-end">
        <button class="btn btn-primary w-100" @onclick="Load">Load</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="alert alert-danger">@Error</div>
}

@if (Loading)
{
    <p>Loading...</p>
}
else if (Payload is not null)
{
    <div class="alert alert-info">
        Total paid: <strong>@Payload.TotalPaid</strong>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Status</th>
                <th>Gateway</th>
                <th>Txn</th>
                <th class="text-end">Amount</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Payload.Payments)
            {
                <tr>
                    <td>@(p.PaidAt ?? p.CreatedAt)</td>
                    <td>@p.Status</td>
                    <td>@p.PaymentGateway</td>
                    <td>@p.TransactionId</td>
                    <td class="text-end">@p.Amount</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool Loading { get; set; }
    private string? Error { get; set; }
    private int SelectedMonth { get; set; } = DateTime.Today.Month;
    private int SelectedYear { get; set; } = DateTime.Today.Year;
    private PaymentsResponse? Payload { get; set; }

    private string MonthValue => $"{SelectedYear:D4}-{SelectedMonth:D2}";

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        Error = null;
        Loading = true;
        Payload = null;
        try
        {
            Payload = await Api.GetAsync<PaymentsResponse>($"office/payments?month={SelectedMonth}&year={SelectedYear}", CancellationToken.None);
        }
        catch
        {
            Error = "Failed to load payments. Ensure you are logged in as Office and API is reachable.";
        }
        finally
        {
            Loading = false;
        }
    }

    private void OnMonthChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? string.Empty;
        var parts = raw.Split('-', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 2 && int.TryParse(parts[0], out var y) && int.TryParse(parts[1], out var m))
        {
            SelectedYear = y;
            SelectedMonth = m;
        }
    }

    private sealed record PaymentsResponse(int Month, int Year, decimal TotalPaid, List<PaymentRow> Payments);
    private sealed record PaymentRow(Guid Id, decimal Amount, string Status, string PaymentGateway, string? TransactionId, DateTimeOffset CreatedAt, DateTimeOffset? PaidAt);
}
