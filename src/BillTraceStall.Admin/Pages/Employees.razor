@page "/employees"
@attribute [Authorize(Roles = "Admin")]

@using System.ComponentModel.DataAnnotations
@inject BillTraceStall.Admin.Services.AdminApiClient Api
@inject BillTraceStall.Admin.Services.AdminSession AdminSession

<h3>Employees (Dashboard Access)</h3>

<div class="mb-3">
    <button class="btn btn-secondary" @onclick="Load" disabled="@_loading">Refresh</button>
</div>

<EditForm Model="_create" OnValidSubmit="Create">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-group">
        <label>Name</label>
        <InputText @bind-Value="_create.Name" class="form-control" />
    </div>
    <div class="form-group">
        <label>Phone</label>
        <InputText @bind-Value="_create.Phone" class="form-control" />
    </div>
    <div class="form-group">
        <label>Password</label>
        <InputText @bind-Value="_create.Password" type="password" class="form-control" />
    </div>
    <div class="form-group">
        <label>Confirm Password</label>
        <InputText @bind-Value="_create.ConfirmPassword" type="password" class="form-control" />
    </div>
    <div class="form-group">
        <label>Designation</label>
        <InputSelect @bind-Value="_create.DesignationName" class="form-control">
            <option value="">-- Select --</option>
            @foreach (var d in ((Designations ?? []).Where(x => x.IsActive)))
            {
                <option value="@d.Name">@d.Name</option>
            }
        </InputSelect>
    </div>
    <div class="form-group">
        <label>Address</label>
        <InputText @bind-Value="_create.Address" class="form-control" />
    </div>

    <button class="btn btn-primary" disabled="@_saving">Create Employee</button>
</EditForm>

<div class="alert alert-info mt-3">
    Employees login using mobile number + password on <a href="/login">Login</a>.
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger mt-3">@_error</div>
}

@if (Items is null)
{
    <p class="mt-3">Loading...</p>
}
else
{
    <table class="table table-striped mt-3">
        <thead>
            <tr>
                <th>Name</th>
                <th>Phone</th>
                <th>Designation</th>
                <th>Active</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Items)
            {
                <tr>
                    <td>@u.Name</td>
                    <td>@u.Phone</td>
                    <td>@(u.Designation ?? "-")</td>
                    <td>@(u.IsActive ? "Yes" : "No")</td>
                    <td>@u.CreatedAt</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading;
    private bool _saving;
    private string _error = string.Empty;
    private List<EmployeeRow>? Items { get; set; }
    private List<DesignationRow>? Designations { get; set; }
    private CreateEmployeeModel _create = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(AdminSession.AccessToken))
        {
            await Load();
        }
    }

    private async Task Load()
    {
        _loading = true;
        _error = string.Empty;
        try
        {
            Designations = await Api.GetAsync<List<DesignationRow>>("/admin/designations", CancellationToken.None) ?? [];
            Items = await Api.GetAsync<List<EmployeeRow>>("/admin/employees", CancellationToken.None) ?? [];
        }
        catch (Exception ex)
        {
            Items = [];
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Create()
    {
        if (!string.Equals(_create.Password, _create.ConfirmPassword, StringComparison.Ordinal))
        {
            _error = "Password and confirm password do not match.";
            return;
        }

        _saving = true;
        _error = string.Empty;
        try
        {
            var body = new
            {
                name = _create.Name.Trim(),
                phone = _create.Phone.Trim(),
                password = _create.Password,
                address = string.IsNullOrWhiteSpace(_create.Address) ? null : _create.Address.Trim(),
                designationName = _create.DesignationName.Trim(),
            };

            var res = await Api.PostAsync("/admin/employees", body, CancellationToken.None);
            if (!res.IsSuccessStatusCode)
            {
                _error = await res.Content.ReadAsStringAsync();
                return;
            }

            _create = new CreateEmployeeModel();
            await Load();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private sealed record EmployeeRow(Guid Id, string Name, string Phone, bool IsActive, DateTimeOffset CreatedAt, string? Designation);
    private sealed record DesignationRow(Guid Id, string Name, bool IsActive, DateTimeOffset CreatedAt);

    private sealed class CreateEmployeeModel
    {
        [Required] public string Name { get; set; } = string.Empty;
        [Required] public string Phone { get; set; } = string.Empty;
        [Required] public string Password { get; set; } = string.Empty;
        [Required] public string ConfirmPassword { get; set; } = string.Empty;
        [Required] public string DesignationName { get; set; } = string.Empty;
        public string? Address { get; set; }
    }
}
