@page "/office/item-wise"
@inject BillTraceStall.Admin.Services.AdminApiClient Api

<h3>Item-wise Orders (Day-wise)</h3>

<div class="row mb-3">
    <div class="col-12 col-md-3">
        <label class="form-label">Month</label>
        <input class="form-control" type="month" value="@MonthValue" @onchange="OnMonthChanged" />
    </div>
    <div class="col-12 col-md-3 d-flex align-items-end">
        <button class="btn btn-primary w-100" @onclick="Load">Load</button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="alert alert-danger">@Error</div>
}

@if (Loading)
{
    <p>Loading...</p>
}
else if (Days is not null && Days.Count == 0)
{
    <p>No orders found for this month.</p>
}
else if (Days is not null)
{
    @foreach (var day in Days)
    {
        <details class="mb-2">
            <summary class="fw-bold">@day.Date</summary>
            <table class="table table-sm table-striped mt-2">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Category</th>
                        <th class="text-end">Qty</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in day.Items)
                    {
                        <tr>
                            <td>@item.ItemName</td>
                            <td>@item.Category</td>
                            <td class="text-end">@item.Qty</td>
                            <td class="text-end">@item.Amount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </details>
    }
}

@code {
    private bool Loading { get; set; }
    private string? Error { get; set; }
    private int SelectedMonth { get; set; } = DateTime.Today.Month;
    private int SelectedYear { get; set; } = DateTime.Today.Year;
    private List<DayGroup>? Days { get; set; }

    private string MonthValue => $"{SelectedYear:D4}-{SelectedMonth:D2}";

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        Error = null;
        Loading = true;
        Days = null;
        try
        {
            var payload = await Api.GetAsync<ItemWiseResponse>($"office/item-wise?month={SelectedMonth}&year={SelectedYear}", CancellationToken.None);
            Days = payload?.Days ?? new List<DayGroup>();
        }
        catch
        {
            Error = "Failed to load item-wise view. Ensure you are logged in as Office and API is reachable.";
            Days = new List<DayGroup>();
        }
        finally
        {
            Loading = false;
        }
    }

    private void OnMonthChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? string.Empty;
        var parts = raw.Split('-', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 2 && int.TryParse(parts[0], out var y) && int.TryParse(parts[1], out var m))
        {
            SelectedYear = y;
            SelectedMonth = m;
        }
    }

    private sealed record ItemWiseResponse(int Month, int Year, List<DayGroup> Days);
    private sealed record DayGroup(string Date, List<ItemRow> Items);
    private sealed record ItemRow(string ItemName, string Category, int Qty, decimal Amount);
}
