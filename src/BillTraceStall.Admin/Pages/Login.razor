@page "/login"
@layout BillTraceStall.Admin.Shared.BlankLayout
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedLocalStorage ProtectedLocalStore
@inject IHttpClientFactory ClientFactory
@inject NavigationManager Navigation
@inject BillTraceStall.Admin.Services.UserSession Session
@inject BillTraceStall.Admin.Services.MailSettingandSend MailService
@inject BillTraceStall.Admin.Services.JwtAuthenticationStateProvider AuthProvider
@inject BillTraceStall.Admin.Services.IAuthCacheService AuthCache
@inject BillTraceStall.Admin.Services.AuthService AuthService
@inject BillTraceStall.Admin.Services.AdminSession AdminSession

@using System.ComponentModel.DataAnnotations
@using System.IdentityModel.Tokens.Jwt
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage

<style>
    .password-input-wrapper {
        position: relative;
    }

    .password-toggle {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #666;
        cursor: pointer;
        padding: 5px;
        font-size: 14px;
    }

    .password-toggle:hover {
        color: #333;
    }
</style>

<div class="az-body az-body-signin">
    <div class="az-signin-wrapper">
        <div class="az-card-signin">
            <h1 class="az-logo">BillTrace</h1>
            <div class="az-signin-header">
                <h2>Welcome back!</h2>
                <h4>Please sign in to continue</h4>
            </div>
            <div class="az-signin-body">
                <div class="mb-3">
                    <div class="btn-group w-100" role="group">
                        <button class="btn @(LoginMode == Mode.Password ? "btn-az-primary" : "btn-outline-secondary")" @onclick="() => SetMode(Mode.Password)">Password (Admin)</button>
                        <button class="btn @(LoginMode == Mode.Otp ? "btn-az-primary" : "btn-outline-secondary")" @onclick="() => SetMode(Mode.Otp)">OTP (Phone Login)</button>
                    </div>
                </div>

                @if (LoginMode == Mode.Password)
                {
                    <EditForm Model="_login" OnValidSubmit="PerformPasswordLogin">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        <div class="form-group">
                            <label>Contact Number</label>
                            <InputText @bind-Value="_login.ContactNumber" placeholder="Enter your contact number" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label>Password</label>
                            <div class="password-input-wrapper">
                                <InputText @bind-Value="_login.Password" type="@(_showLoginPassword ? "text" : "password")" placeholder="Enter your password" class="form-control" />
                                <button type="button" class="password-toggle" @onclick="() => _showLoginPassword = !_showLoginPassword">
                                    @if (_showLoginPassword)
                                    {
                                        <i class="fas fa-eye-slash"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-eye"></i>
                                    }
                                </button>
                            </div>
                        </div>
                        <button class="btn btn-az-primary btn-block" disabled="@_passwordLoggingIn">Sign In</button>
                    </EditForm>
                }
                else
                {
                    <EditForm Model="_otpLogin" OnValidSubmit="VerifyOtpLogin">
                        <DataAnnotationsValidator />
                        <ValidationSummary />
                        <div class="form-group">
                            <label>Contact Number</label>
                            <InputText @bind-Value="_otpLogin.ContactNumber" placeholder="Enter your contact number" class="form-control" />
                        </div>
                        <div class="form-group d-flex align-items-center">
                            <button type="button" class="btn btn-outline-secondary mr-2" disabled="@_otpSending" @onclick="RequestOtp">Send OTP</button>
                            <span class="text-muted">@_otpStatus</span>
                        </div>
                        <div class="form-group">
                            <label>OTP</label>
                            <InputText @bind-Value="_otpLogin.Otp" placeholder="Enter OTP" class="form-control" />
                        </div>
                        <button class="btn btn-az-primary btn-block" disabled="@_otpVerifying">Verify & Sign In</button>
                    </EditForm>
                }

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger mt-3">@_error</div>
                }
                @if (!string.IsNullOrEmpty(_success))
                {
                    <div class="alert alert-success mt-3">@_success</div>
                }
            </div>
            <div class="az-signin-footer">
                <p>Don't have an account? <a href="/register">Create an Account</a></p>
            </div>
        </div>
    </div>
</div>

@code {
    private string _error = string.Empty;
    private string _success = string.Empty;
    private bool _showLoginPassword;
    private bool _initializedAfterRender;
    private bool _passwordLoggingIn;
    private bool _otpSending;
    private bool _otpVerifying;
    private string _otpStatus = string.Empty;
    private Mode LoginMode { get; set; } = Mode.Password;

    private LoginRequest _login = new();
    private OtpLoginRequest _otpLogin = new();

    protected override Task OnInitializedAsync()
    {
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initializedAfterRender)
        {
            return;
        }

        _initializedAfterRender = true;

        try
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            if (authState?.User?.Identity?.IsAuthenticated == true)
            {
                Navigation.NavigateTo("/dashboard", forceLoad: true);
                return;
            }
        }
        catch
        {
        }

        try
        {
            await TryAutoLogin();
        }
        catch (InvalidOperationException)
        {
            return;
        }
    }

    private async Task TryAutoLogin()
    {
        try
        {
            ProtectedBrowserStorageResult<string> storedUser;
            ProtectedBrowserStorageResult<string> storedPass;
            ProtectedBrowserStorageResult<string> storedToken;

            try
            {
                storedUser = await ProtectedLocalStore.GetAsync<string>("auth_user");
                storedPass = await ProtectedLocalStore.GetAsync<string>("auth_pass");
                storedToken = await ProtectedLocalStore.GetAsync<string>("auth_token");
            }
            catch
            {
                return;
            }

            if (!storedUser.Success || string.IsNullOrWhiteSpace(storedUser.Value))
            {
                return;
            }

            var cachedToken = await AuthService.GetCachedTokenAsync(storedUser.Value, CancellationToken.None);
            var tokenToUse = cachedToken ?? (storedToken.Success ? storedToken.Value : null);

            if (!string.IsNullOrWhiteSpace(tokenToUse))
            {
                Session.Token = tokenToUse;
                Session.ContactNumber = storedUser.Value;
                Session.LoginTime = DateTime.Now;
                Session.EmployeeId = 0;
                Session.NotifyStateChanged();

                AdminSession.SetToken(tokenToUse);
                await AuthProvider.MarkUserAsAuthenticatedAsync(tokenToUse, storedUser.Value);

                await Task.Delay(250);
                Navigation.NavigateTo("/dashboard", true);
            }
        }
        catch
        {
            return;
        }
    }

    private async Task ClearAllAuthData()
    {
        AuthCache.Clear();
        try { await ProtectedLocalStore.DeleteAsync("auth_token"); } catch { }
        try { await ProtectedLocalStore.DeleteAsync("auth_user"); } catch { }
        try { await ProtectedLocalStore.DeleteAsync("auth_pass"); } catch { }
        try { await ProtectedLocalStore.DeleteAsync("last_auto_login_attempt"); } catch { }
        Session.Clear();
        await AuthProvider.MarkUserAsLoggedOutAsync();
    }

    private async Task PerformLogin()
    {
        await PerformPasswordLogin();
    }

    private void SetMode(Mode mode)
    {
        LoginMode = mode;
        _error = _success = string.Empty;
        _otpStatus = string.Empty;
    }

    private async Task PerformPasswordLogin()
    {
        _error = _success = string.Empty;
        _passwordLoggingIn = true;

        try
        {
            if (string.IsNullOrWhiteSpace(_login.ContactNumber) || string.IsNullOrWhiteSpace(_login.Password))
            {
                _error = "❌ Please enter both contact number and password.";
                return;
            }

            _success = "🔄 Authenticating...";

            var (token, errorMessage) = await AuthService.LoginWithPasswordWithErrorAsync(_login.ContactNumber, _login.Password, CancellationToken.None);
            if (string.IsNullOrWhiteSpace(token))
            {
                _error = $"❌ {errorMessage ?? "Login failed."}";
                _success = string.Empty;
                return;
            }

            var role = GetRoleFromToken(token);
            if (!string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase))
            {
                _error = "❌ Password login is allowed only for Admin.";
                _success = string.Empty;
                return;
            }

            Session.Token = token;
            Session.ContactNumber = _login.ContactNumber;
            Session.LoginTime = DateTime.Now;
            Session.EmployeeId = 0;
            Session.NotifyStateChanged();

            AdminSession.SetToken(token);

            await ProtectedLocalStore.SetAsync("auth_token", token);
            await ProtectedLocalStore.SetAsync("auth_user", _login.ContactNumber);
            await ProtectedLocalStore.SetAsync("auth_pass", _login.Password);

            await AuthProvider.MarkUserAsAuthenticatedAsync(token, _login.ContactNumber);

            _success = "✅ Login successful! Redirecting...";
            _error = string.Empty;

            await Task.Delay(250);
            Navigation.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            _error = $"❌ Login failed: {ex.Message}";
            _success = string.Empty;
        }
        finally
        {
            _passwordLoggingIn = false;
        }
    }

    private async Task RequestOtp()
    {
        _error = _success = string.Empty;
        _otpStatus = string.Empty;

        if (string.IsNullOrWhiteSpace(_otpLogin.ContactNumber))
        {
            _error = "❌ Please enter contact number.";
            return;
        }

        _otpSending = true;
        try
        {
            var client = ClientFactory.CreateClient("api");
            var res = await client.PostAsJsonAsync("auth/login", new { phone = _otpLogin.ContactNumber }, CancellationToken.None);
            if (!res.IsSuccessStatusCode)
            {
                var text = await res.Content.ReadAsStringAsync(CancellationToken.None);
                _otpStatus = string.IsNullOrWhiteSpace(text) ? "OTP request failed." : text;
                return;
            }

            _otpStatus = "OTP sent.";
        }
        catch
        {
            _otpStatus = "OTP request failed.";
        }
        finally
        {
            _otpSending = false;
        }
    }

    private async Task VerifyOtpLogin()
    {
        _error = _success = string.Empty;

        if (string.IsNullOrWhiteSpace(_otpLogin.ContactNumber) || string.IsNullOrWhiteSpace(_otpLogin.Otp))
        {
            _error = "❌ Please enter contact number and OTP.";
            return;
        }

        _otpVerifying = true;
        try
        {
            var (token, errorMessage) = await AuthService.VerifyOtpOnlyWithErrorAsync(_otpLogin.ContactNumber, _otpLogin.Otp, CancellationToken.None);
            if (string.IsNullOrWhiteSpace(token))
            {
                _error = $"❌ {errorMessage ?? "OTP verification failed."}";
                return;
            }

            Session.Token = token;
            Session.ContactNumber = _otpLogin.ContactNumber;
            Session.LoginTime = DateTime.Now;
            Session.EmployeeId = 0;
            Session.NotifyStateChanged();

            AdminSession.SetToken(token);

            await ProtectedLocalStore.SetAsync("auth_token", token);
            await ProtectedLocalStore.SetAsync("auth_user", _otpLogin.ContactNumber);
            try { await ProtectedLocalStore.DeleteAsync("auth_pass"); } catch { }

            await AuthProvider.MarkUserAsAuthenticatedAsync(token, _otpLogin.ContactNumber);

            _success = "✅ Login successful! Redirecting...";
            await Task.Delay(250);
            Navigation.NavigateTo("/dashboard", true);
        }
        catch (Exception ex)
        {
            _error = $"❌ Login failed: {ex.Message}";
        }
        finally
        {
            _otpVerifying = false;
        }
    }

    private static string? GetRoleFromToken(string token)
    {
        try
        {
            var handler = new JwtSecurityTokenHandler();
            var jwt = handler.ReadJwtToken(token);
            var role = jwt.Claims.FirstOrDefault(c =>
                    string.Equals(c.Type, "role", StringComparison.OrdinalIgnoreCase)
                    || string.Equals(c.Type, "http://schemas.microsoft.com/ws/2008/06/identity/claims/role", StringComparison.OrdinalIgnoreCase))
                ?.Value;
            return role;
        }
        catch
        {
            return null;
        }
    }

    public class LoginRequest
    {
        [Required] public string ContactNumber { get; set; } = string.Empty;
        [Required] public string Password { get; set; } = string.Empty;
    }

    public sealed class OtpLoginRequest
    {
        [Required] public string ContactNumber { get; set; } = string.Empty;
        [Required] public string Otp { get; set; } = string.Empty;
    }

    private enum Mode
    {
        Password = 1,
        Otp = 2
    }
}
